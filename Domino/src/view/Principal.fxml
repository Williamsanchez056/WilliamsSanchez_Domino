<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #2d5a27;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.JuegoController">
   <children>
      <Label layoutX="425.0" layoutY="25.0" text="Dominó" textFill="WHITE">
         <font>
            <Font name="System Bold" size="42.0" />
         </font>
      </Label>

      <VBox alignment="CENTER" layoutX="50.0" layoutY="150.0" prefHeight="300.0" prefWidth="900.0" style="-fx-border-color: #ffffff55; -fx-border-radius: 20; -fx-border-width: 3; -fx-border-style: dashed;">
         <children>
            <HBox fx:id="contenedorTablero" alignment="CENTER" prefHeight="100.0" prefWidth="850.0" spacing="10.0" />
         </children>
      </VBox>

      <VBox alignment="CENTER" layoutX="50.0" layoutY="500.0" prefHeight="150.0" prefWidth="900.0" spacing="10.0">
         <children>
            <Label text="Tus Fichas" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <HBox fx:id="contenedorManoJugador" alignment="CENTER" prefHeight="100.0" prefWidth="800.0" spacing="15.0" style="-fx-background-color: #00000033; -fx-background-radius: 15;" />
         </children>
      </VBox>

      <Button layoutX="880.0" layoutY="30.0" mnemonicParsing="false" onAction="#reiniciarPartida" text="Reiniciar" />
   </children>
</AnchorPane>